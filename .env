DATABASE_URL=postgresql://expatuser:expatpass@localhost:5432/expatdb
SESSION_SECRET=dev-secret-key-change-in-production-256-bits-minimum
NODE_ENV=production
PORT=3001
BCRYPT_ROUNDS=12

# =============================================================================
# GOOGLE OAUTH CONFIGURATION
# =============================================================================
# Get these from: https://console.cloud.google.com/
# 1. Create a new project or select existing
# 2. Enable Google+ API
# 3. Create OAuth 2.0 Client ID credentials
# 4. Copy Client ID and Secret here

GOOGLE_CLIENT_ID=818571166712-5hs1cgoeic9s8jb495vjmdc0qm7kd213.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_CALLBACK_URL=https://expateatsguide.com/api/auth/google/callback

# Development callback URL:
# GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# =============================================================================
# SENDGRID EMAIL CONFIGURATION
# =============================================================================
# Get API key from: https://sendgrid.com/
# 1. Create SendGrid account
# 2. Verify sender email address(es)
# 3. Create API Key with "Mail Send" permissions
# 4. Copy API key here

SENDGRID_API_KEY=YOUR_ACTUAL_API_KEY_HERE
SENDGRID_VERIFIED_SENDER=noreply@expateatsguide.com

# =============================================================================
# EMAIL ADDRESSES
# =============================================================================
# These should all be verified in SendGrid

ADMIN_EMAIL=admin@expateatsguide.com
SUPPORT_EMAIL=hello@expateatsguide.com
NEWSLETTER_EMAIL=newsletter@expateatsguide.com

# =============================================================================
# APPLICATION URLS
# =============================================================================
# Used for generating links in emails

FRONTEND_URL=https://expateatsguide.com

# Development URL:
# FRONTEND_URL=http://localhost:3001

# =============================================================================
# EMAIL SERVICE SETTINGS
# =============================================================================

EMAIL_ENABLED=true
EMAIL_DEBUG=true
EMAIL_RATE_LIMIT=100

# Unsubscribe URL
UNSUBSCRIBE_URL=https://expateatsguide.com/unsubscribe
# Development: UNSUBSCRIBE_URL=http://localhost:3001/unsubscribe

# =============================================================================
# GEOAPIFY GEOCODING CONFIGURATION
# =============================================================================
# Get API key from: https://www.geoapify.com/
# Used for address geocoding and location services

GEOAPIFY_API_KEY=3c1197c9a8584ee2bec672f71aa59125

# =============================================================================
# DATABASE SEEDING SETTINGS
# =============================================================================
# Set to false to prevent clearing tables on app restart
CLEAR_TABLES=false
